{
  "name": "@betteroffice/docx-react",
  "version": "0.0.1",
  "description": "Word-faithful React DOCX editor and viewer — full OOXML fidelity, real-time human + AI agent collaboration.",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && bun run build:css",
    "build:css": "tailwindcss -c ./tailwind.config.js -i ./src/styles/editor.css -o ./dist/styles.css --minify",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@betteroffice/docx": "workspace:*",
    "@betteroffice/docx-i18n": "workspace:*",
    "@radix-ui/react-select": "^2.2.6",
    "clsx": "^2.1.0",
    "sonner": "^2.0.7"
  },
  "keywords": [
    "docx",
    "word",
    "document",
    "ooxml",
    "editor",
    "viewer",
    "react",
    "collaborative",
    "real-time",
    "ai-agent"
  ],
  "author": "OpenOOXML",
  "license": "Apache-2.0",
  "homepage": "https://betteroffice.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/openooxml/betteroffice.git",
    "directory": "packages/docx-react"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^6.0.3",
    "@types/bun": "^1.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "class-variance-authority": "^0.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@testing-library/react": "^16.0.0",
    "@happy-dom/global-registrator": "^20.8.3"
  }
}
