{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"],
      "@betteroffice/xlsx": ["../xlsx/src/index.ts"],
      "@betteroffice/xlsx-i18n": ["../xlsx-i18n/src/index.ts"],
      "@betteroffice/xlsx/headless": ["../xlsx/src/headless.ts"],
      "@betteroffice/xlsx/*": ["../xlsx/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
