{
  "name": "@betteroffice/demo",
  "private": true,
  "version": "0.0.5",
  "scripts": {
    "build:deck": "bun ../../scripts/create-demo-deck.ts",
    "build:wasm": "bun ../../scripts/build-xlsx-wasm.ts && bun ../../scripts/build-docx-wasm.ts && bun ../../scripts/build-pptx-wasm.ts",
    "build:seeds": "bun scripts/build-collaboration-seeds.ts",
    "predev": "bun run build:deck && bun run build:wasm && bun run build:seeds",
    "dev": "next dev",
    "prebuild": "bun run build:deck && bun run build:wasm && bun run build:seeds",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@betteroffice/pptx": "workspace:*",
    "@betteroffice/pptx-react": "workspace:*",
    "@betteroffice/xlsx": "workspace:*",
    "@betteroffice/xlsx-react": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "@betteroffice/docx": "workspace:*",
    "@betteroffice/docx-react": "workspace:*",
    "@betteroffice/docx-fonts": "workspace:*"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
